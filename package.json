{
  "name": "wilkins-global-guest-os",
  "version": "1.0.0",
  "private": true,
  "description": "Wilkins Media Global Guest OS — multilingual event experience platform for global live events",
  "scripts": {
    "activate": "powershell -ExecutionPolicy Bypass -File ./scripts/activate-wilkins.ps1",
    "activate:fth": "powershell -ExecutionPolicy Bypass -File ./scripts/activate-wilkins.ps1 -Brand fthtrading-fifa-wilkins",
    "pages:sync-brand": "powershell -ExecutionPolicy Bypass -File ./scripts/activate-wilkins.ps1 -PagesOnly -Brand fthtrading-fifa-wilkins",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "pnpm --filter @wilkins/api run db:generate",
    "db:migrate": "pnpm --filter @wilkins/api run db:migrate",
    "db:seed": "pnpm --filter @wilkins/api run db:seed",
    "db:seed:atlanta": "npx ts-node scripts/seed-atlanta.ts",
    "db:studio": "pnpm --filter @wilkins/api run db:studio"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/minimatch": "5.1.2",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
