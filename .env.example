# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=4000
# REQUIRED in production — min 32 characters.
# Generate: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_32_PLUS_CHAR_RANDOM_SECRET
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://wilkins:wilkins_dev@localhost:5432/wilkins
POSTGRES_PASSWORD=wilkins_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=wilkins_dev

# ─── Translation Providers ────────────────────────────────────────────────────
# Choose one: azure | google | deepl
TRANSLATION_PROVIDER=azure

# Azure Cognitive Services Translator
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=eastus

# Google Cloud Translation (alternative)
GOOGLE_TRANSLATE_KEY=

# DeepL (alternative)
DEEPL_API_KEY=

# ─── Vision / OCR ─────────────────────────────────────────────────────────────
OCR_PROVIDER=azure
AZURE_VISION_KEY=
AZURE_VISION_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/

# ─── Speech (TTS / STT) ───────────────────────────────────────────────────────
TTS_PROVIDER=azure
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ─── Mapbox ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
MAPBOX_ACCESS_TOKEN=
OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter

# ─── Agentic RAG / MCP ───────────────────────────────────────────────────────
MCP_AGENTIC_ENABLED=true
# Options: pgvector | local
RAG_PROVIDER=pgvector

# Embedding provider for RAG ingestion (openai | azure-openai)
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Azure OpenAI alternative
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
RAG_VECTOR_INDEX=wilkins-cultural-index

# ─── Sponsor / Campaigns ─────────────────────────────────────────────────────
SPONSOR_INJECTION_ENABLED=true
MAX_SPONSOR_DENSITY=2
SPONSOR_RATIO=0.2

# ─── Telecom / Telnyx (Text FIFA) ────────────────────────────────────────────
TELECOM_PROVIDER=telnyx
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_CONNECTION_ID=
TELNYX_PHONE_NUMBER=+18888273432
TELECOM_DEFAULT_EVENT_ID=
TELECOM_DEFAULT_VENUE_ID=mercedes-benz-stadium
TELECOM_PUBLIC_BASE_URL=http://localhost:3000
SHORT_LINK_BASE_URL=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_BURST=20
RATE_LIMIT_PER_MINUTE=200

# ─── Multi-Tenant ─────────────────────────────────────────────────────────────
# TENANT_SLUG=wilkins-media

# ─── Next.js (Public vars) ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_DEFAULT_EVENT_ID=
NEXT_PUBLIC_EVENT_SLUG=atlanta-2026

# Default venue and event IDs — override per deployment
NEXT_PUBLIC_DEFAULT_VENUE_ID=mercedes-benz-stadium
NEXT_PUBLIC_DEFAULT_EVENT_ID=atlanta-2026
